{
    "name": "vending-machine/app",
    "description": "PHP Vending Machine — senior engineering challenge",
    "type": "project",
    "require": {
        "php": "^8.4",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts" : {
        "test": "docker compose exec app vendor/bin/phpunit",
        "stan": "docker compose exec app vendor/bin/phpstan analyse src --level=8",
        "fix": "docker compose exec app vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes"
    }
}
